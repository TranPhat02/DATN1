            <mxPoint x="559" y="440" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m6" value="7. update_one({lockType}) trong MongoDB" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
