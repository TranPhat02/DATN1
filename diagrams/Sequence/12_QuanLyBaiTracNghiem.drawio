            <mxPoint x="309" y="670" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m9" value="10. DELETE /api/v1/quiz/{quizId}" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
