            <mxPoint x="819" y="280" as="sourcePoint" />
            <mxPoint x="560" y="280" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- === KHOA / MO KHOA === -->
        <mxCell id="grp_lock" value="[Thay doi trang thai khoa]" style="shape=mxgraph.sequence.fragment;whiteSpace=wrap;html=1;fontColor=#FFFFFF;strokeColor=#FFFFFF;fillColor=none;fontSize=11;align=left;verticalAlign=top;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="75" y="350" width="780" height="250" as="geometry" />
        </mxCell>
        <mxCell id="m4" value="5. Chon quiz va nhan Khoa/Mo khoa" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="95" y="390" as="sourcePoint" />
            <mxPoint x="309" y="390" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m5" value="6. PUT /api/v1/quiz/lock/{quizId} {lockType: 0/1}" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
