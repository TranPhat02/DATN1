            <mxPoint x="559" y="720" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m10" value="11. delete_one({_id: quizId}) tu MongoDB" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
