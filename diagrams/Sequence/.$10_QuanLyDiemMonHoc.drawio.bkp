        <mxCell id="m2" value="2. PUT /api/v1/diem-mon-hoc/{ma_diem}" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
