        <mxCell id="m1" value="1. Nhap/sua DiemGK va DiemCK cho sinh vien" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
