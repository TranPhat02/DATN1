        <mxCell id="m3" value="3. SELECT DiemMonHoc WHERE MaDiem = ? (MySQL)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
