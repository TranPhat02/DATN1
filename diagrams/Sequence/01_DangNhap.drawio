        <mxCell id="l2" value="" style="line;strokeWidth=1;fillColor=none;align=left;verticalAlign=middle;spacingTop=-1;spacingLeft=3;spacingRight=10;rotatable=0;labelPosition=left;points=[];portConstraint=eastwest;strokeColor=#FFFFFF;fontColor=#FFFFFF;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="299" y="100" width="1" height="650" as="geometry" />
        </mxCell>
        <!-- Participant: Backend API -->
        <mxCell id="a3" value="Backend API&#xa;(FastAPI)" style="shape=mxgraph.flowchart.multi-document;whiteSpace=wrap;html=1;fontColor=#FFFFFF;strokeColor=#FFFFFF;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="500" y="30" width="100" height="55" as="geometry" />
        </mxCell>
        <mxCell id="l3" value="" style="line;strokeWidth=1;fillColor=none;align=left;verticalAlign=middle;spacingTop=-1;spacingLeft=3;spacingRight=10;rotatable=0;labelPosition=left;points=[];portConstraint=eastwest;strokeColor=#FFFFFF;fontColor=#FFFFFF;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="549" y="100" width="1" height="650" as="geometry" />
        </mxCell>
        <!-- Participant: Database -->
        <mxCell id="a4" value="Database&#xa;(MySQL)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fontColor=#FFFFFF;strokeColor=#FFFFFF;fillColor=none;fontSize=11;" vertex="1" parent="1">
