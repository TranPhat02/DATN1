        </mxCell>
        <!-- Participant: Frontend -->
        <mxCell id="a2" value="Frontend&#xa;(React)" style="shape=mxgraph.flowchart.multi-document;whiteSpace=wrap;html=1;fontColor=#FFFFFF;strokeColor=#FFFFFF;fillColor=none;fontSize=11;" vertex="1" parent="1">
