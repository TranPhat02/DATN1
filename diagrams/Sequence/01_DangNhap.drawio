        </mxCell>
        <mxCell id="l4" value="" style="line;strokeWidth=1;fillColor=none;align=left;verticalAlign=middle;spacingTop=-1;spacingLeft=3;spacingRight=10;rotatable=0;labelPosition=left;points=[];portConstraint=eastwest;strokeColor=#FFFFFF;fontColor=#FFFFFF;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="789" y="100" width="1" height="650" as="geometry" />
        </mxCell>
        <!-- Step 1: User enters credentials -->
        <mxCell id="m1" value="1. Nhap username va mat khau" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="95" y="140" as="sourcePoint" />
            <mxPoint x="299" y="140" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 2: Frontend sends POST /api/v1/auth/login -->
        <mxCell id="m2" value="2. POST /api/v1/auth/login (form-data)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="190" as="sourcePoint" />
            <mxPoint x="549" y="190" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 3: Backend queries DB -->
        <mxCell id="m3" value="3. SELECT TaiKhoan WHERE UserName = ?" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="240" as="sourcePoint" />
            <mxPoint x="789" y="240" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 4: DB returns user record -->
        <mxCell id="m4" value="4. Tra ve ban ghi TaiKhoan" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="789" y="290" as="sourcePoint" />
            <mxPoint x="550" y="290" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Step 5: Verify password -->
        <mxCell id="m5" value="5. Xac minh mat khau (verify_password)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
