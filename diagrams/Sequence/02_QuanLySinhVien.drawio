            <mxPoint x="550" y="530" as="sourcePoint" />
            <mxPoint x="1019" y="530" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <!-- Auto enroll -->
        <mxCell id="grp2" value="[Tu dong ghi danh vao lop mon hoc]" style="shape=mxgraph.sequence.fragment;whiteSpace=wrap;html=1;fontColor=#FFFFFF;strokeColor=#FFFFFF;fillColor=none;fontSize=11;align=left;verticalAlign=top;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="530" y="610" width="290" height="240" as="geometry" />
        </mxCell>
        <mxCell id="m7" value="8. SELECT LopMonHoc WHERE MaLop = SV.MaLop" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
