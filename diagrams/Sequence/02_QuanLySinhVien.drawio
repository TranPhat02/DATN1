        <!-- Messages -->
        <mxCell id="m1" value="1. Nhap thong tin sinh vien (TenSV, MaLop, Gmail...)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
