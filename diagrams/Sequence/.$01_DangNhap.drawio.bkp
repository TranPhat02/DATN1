            <mxPoint x="95" y="140" as="sourcePoint" />
            <mxPoint x="299" y="140" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 2: Frontend sends POST /api/v1/auth/login -->
        <mxCell id="m2" value="2. POST /api/v1/auth/login (form-data)" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="190" as="sourcePoint" />
            <mxPoint x="549" y="190" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Step 3: Backend queries DB -->
        <mxCell id="m3" value="3. SELECT TaiKhoan WHERE UserName = ?" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
