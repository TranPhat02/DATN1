        <!-- Step 1: User enters credentials -->
        <mxCell id="m1" value="1. Nhap username va mat khau" style="html=1;verticalAlign=bottom;endArrow=block;curved=0;rounded=0;strokeColor=#FFFFFF;fontColor=#FFFFFF;fontSize=11;" edge="1" parent="1">
